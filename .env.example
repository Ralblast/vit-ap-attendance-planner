# Firebase Web SDK (exposed to client bundle)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Admin UX hint (server still verifies via Firebase custom claims)
VITE_ADMIN_EMAIL=

# Optional projection cutoffs displayed in the planner
VITE_CAT1_START_DATE=
VITE_CAT2_START_DATE=
VITE_FAT_START_DATE=

# Comma-separated extra hosts allowed by the dev server (e.g. ngrok)
VITE_DEV_ALLOWED_HOSTS=

# Backend service account for cron + admin endpoints
FIREBASE_SERVICE_ACCOUNT=

# SMTP for review/alert emails
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Email defaults
ATTENDANCE_REVIEW_FROM=
ATTENDANCE_REVIEW_TO=
ATTENDANCE_REVIEW_SUBJECT=Weekly attendance review
ATTENDANCE_REVIEW_TEXT=Time to review your attendance for the week.

# Vercel cron secret
CRON_SECRET=

# First-time admin bootstrap (sets the `admin` custom claim)
ADMIN_BOOTSTRAP_PASSWORD=
